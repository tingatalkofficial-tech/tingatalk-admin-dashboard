rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admin to update verification status on user documents
    match /users/{userId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isVerified', 'verificationStatus']);
    }

    // All other collections: read-only
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
